<Window x:Class="LacuarinEWPFApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anime Shop"
        Height="500" Width="900"
        Background="#2E1A47">

    
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0">

            <Label Content="PURCHASE POPULAR ANIME"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalContentAlignment="Center"/>

            <Separator Margin="0,5"/>

            <DataGrid x:Name="dataGrid"
                      Height="300"
                      AutoGenerateColumns="False"
                      SelectionChanged="dataGrid_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Anime" Binding="{Binding AnimeName}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="*"/>
                    <DataGridTextColumn Header="Season" Binding="{Binding Season}" Width="*"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="*"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

            <Button x:Name="btnDeleteData"
                    Content="Delete Selected"
                    Background="#FFB6B6"
                    IsEnabled="False"
                    Click="btnDeleteData_Click"/>
        </StackPanel>

        
        <Border Grid.Column="1"
                Background="#3E2A5E"
                Padding="15"
                CornerRadius="10">

            <StackPanel>

                <Label Content="Anime Details"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalContentAlignment="Center"/>

                
                <Label Content="Anime Name"/>
                <TextBox x:Name="txtName"/>

                
                <Label Content="Price"/>
                <TextBox x:Name="txtPrice"/>

                
                <Label Content="Genre"/>
                <ComboBox x:Name="comboBoxGenre">
                    <ComboBoxItem Content="Fantasy"/>
                    <ComboBoxItem Content="Adventure"/>
                    <ComboBoxItem Content="Action"/>
                    <ComboBoxItem Content="Love Story"/>
                    <ComboBoxItem Content="Horror"/>
                </ComboBox>

                
                <Label Content="Season"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton x:Name="rbOne" Content="1" GroupName="Season" Margin="5"/>
                    <RadioButton x:Name="rbTwo" Content="2" GroupName="Season" Margin="5"/>
                    <RadioButton x:Name="rbThree" Content="3" GroupName="Season" Margin="5"/>
                    <RadioButton x:Name="rbFour" Content="4" GroupName="Season" Margin="5"/>
                </StackPanel>

                
                <Label Content="Discount"/>
                <TextBox x:Name="txtDiscount"/>

                <Button x:Name="btnSave"
                        Content="Save"
                        Background="#C3F0CA"
                        Click="btnSave_Click"
                        Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window> 